{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/server",
  "framework": "other",
  "installCommand": "npm install --legacy-peer-deps || npm install",
  "routes": [
    {
      "src": "^(?!.*\\.\\w+$).*$",
      "dest": "/index.js"
    },
    {
      "src": "^/(.*)$",
      "dest": "/index.js"
    }
  ],
  "env": {
    "NODE_OPTIONS": "-–experimental-modules"
  }
}
